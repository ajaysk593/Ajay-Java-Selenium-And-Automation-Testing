package HarithaTestCases;

package HarithaTestCases;

import java.time.Duration;
import org.openqa.selenium.*;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;

public class yug {

    public static void main(String[] args) throws Exception {

        WebDriver driver = new ChromeDriver();
        WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(10));
        JavascriptExecutor js = (JavascriptExecutor) driver;

        driver.manage().window().maximize();
        driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(10));

        driver.get("file:///C:/Users/dell/Desktop/Main_Repo/SaiMohan_OnlineStoreWebsite_FrontEndFiles/online_store.html");
        System.out.println("STEP 1: Application Launch → PASSED");

        // ===== Navigation =====
        wait.until(ExpectedConditions.visibilityOfElementLocated(By.linkText("Home")));
        wait.until(ExpectedConditions.visibilityOfElementLocated(By.linkText("Shop")));
        wait.until(ExpectedConditions.visibilityOfElementLocated(By.linkText("About")));
        wait.until(ExpectedConditions.visibilityOfElementLocated(By.linkText("Contact")));
        System.out.println("STEP 2: Navigation Menu Verified → PASSED");

        driver.findElement(By.linkText("Shop")).click();
        Thread.sleep(800);
        driver.findElement(By.linkText("About")).click();
        Thread.sleep(800);
        driver.findElement(By.linkText("Contact")).click();
        Thread.sleep(800);
        driver.findElement(By.linkText("Home")).click();
        System.out.println("STEP 3: Navigation Links Working → PASSED");

        // ===== Search Feature =====
        WebElement searchBox = driver.findElement(By.xpath("//input[@placeholder='Search...']"));
        searchBox.clear();
        searchBox.sendKeys("Laptop");
        Thread.sleep(1000);
        System.out.println("STEP 4: Search Box Working → PASSED");

        // ===== Wishlist & Cart Icon Existence =====
        driver.findElement(By.xpath("//*[contains(@class,'heart')]")).isDisplayed();
        driver.findElement(By.xpath("//*[contains(@class,'cart')]")).isDisplayed();
        System.out.println("STEP 5: Wishlist & Cart Icons Visible → PASSED");

        // ===== Add Items to Cart & Wishlist =====
        for (int i = 1; i <= 4; i++) {

            if (i == 3) {
                js.executeScript("window.scrollBy(0,600)");
                Thread.sleep(800);
            }

            WebElement qty = driver.findElement(By.xpath("(//input[@type='number'])[" + i + "]"));
            qty.clear();
            qty.sendKeys(i == 3 ? "2" : "1");

            driver.findElement(By.xpath("(//button[contains(text(),'Add to Cart')])[" + i + "]")).click();
            driver.findElement(By.xpath("(//button[contains(text(),'Wishlist')])[" + i + "]")).click();

            System.out.println("STEP 6." + i + ": Product " + i + " Added → PASSED");
        }

        System.out.println("STEP 6: All Products Added Successfully → PASSED");

        // ===== Scroll to Footer =====
        js.executeScript("window.scrollTo(0, document.body.scrollHeight)");
        Thread.sleep(1000);

        String location = driver.findElement(By.xpath("//*[contains(text(),'Hyderabad, India')]")).getText();
        System.out.println("STEP 7: Footer Verified (Location: " + location + ") → PASSED");

        // ===== WhatsApp Button Test =====
        driver.findElement(By.xpath("//button[contains(text(),'WhatsApp')]")).click();
        System.out.println("STEP 8: WhatsApp Button Click Working → PASSED");

        // ===== Test Completed =====
        Thread.sleep(2000);
        driver.quit();
        System.out.println("🎯 ALL STEPS PASSED SUCCESSFULLY – AUTOMATION RUN COMPLETED! ✔");
    }
}
