package HarithaTestCases;

import java.time.Duration;
import java.util.List;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;

public class OnlineShoppingTestCases {


		    public static void main(String[] args) throws InterruptedException {

		        WebDriver driver = new ChromeDriver();
		        driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(10));
		        driver.manage().window().maximize();

		        // 👉 Load your local webpage / hosted page
		        driver.get("file:///C:/Users/YourPC/Desktop/index.html");

		        // 1️⃣ Validate Product List is Loaded
		        List<WebElement> products = driver.findElements(By.className("card"));
		        System.out.println("Total Products Displayed: " + products.size());

		        if (products.size() > 0) {
		            System.out.println("✔ Products are visible on page");
		        } else {
		            System.out.println("❌ Products NOT visible");
		        }

		        // 2️⃣ Add First Product to Cart
		        driver.findElements(By.xpath("//button[text()='Add to Cart']")).get(0).click();
		        Thread.sleep(1000);

		        // 3️⃣ Add Second Product to Cart
		        driver.findElements(By.xpath("//button[text()='Add to Cart']")).get(1).click();
		        Thread.sleep(1000);

		        // 4️⃣ Open Cart Modal
		        driver.findElement(By.id("cartIcon")).click();
		        Thread.sleep(1000);

		        // 5️⃣ Validate Cart Count
		        String cartCount = driver.findElement(By.id("cartCount")).getText();
		        System.out.println("Cart Count: " + cartCount);

		        if (cartCount.equals("2")) {
		            System.out.println("✔ Cart Count updated successfully");
		        } else {
		            System.out.println("❌ Cart Count mismatch");
		        }

		        // 6️⃣ Remove First Product from Cart
		        driver.findElement(By.xpath("(//button[text()='Remove'])[1]")).click();
		        Thread.sleep(1000);

		        // 7️⃣ Validate updated cart count
		        String updatedCart = driver.findElement(By.id("cartCount")).getText();
		        System.out.println("Updated Cart Count: " + updatedCart);

		        // End Test
		        driver.quit();
		    }
		}

